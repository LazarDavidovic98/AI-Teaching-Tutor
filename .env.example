# ─────────────────────────────────────────────────────────────────────────────
# AI Teaching Tutor – Primjer .env fajla
# Kopiraj ovaj fajl kao .env i popuni svoje vrijednosti.
# NIKADA ne commituj .env u git repozitorij!
# ─────────────────────────────────────────────────────────────────────────────

# ── Sigurnost JWT-a ───────────────────────────────────────────────────────────
# Generiši nasumičan string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=promijeni-ovo-u-produkciji-koristeci-nasumican-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Baza podataka ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./ai_tutor.db
# Za PostgreSQL:
# DATABASE_URL=postgresql://korisnik:lozinka@localhost:5432/ai_tutor_db

# ── OpenAI / LLM ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-tvoj-kljuc-ovdje
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Lokalni LLM (Ollama) – samo promijeni ove dvije linije:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# ── Embeddinzi ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small

# Lokalni embeddinzi (SentenceTransformers) – potpuno besplatno:
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=tutor_documents

# ── Upload ─────────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
